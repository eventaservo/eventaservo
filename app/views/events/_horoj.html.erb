<% unless @event.all_day? %>
  <div class="small text-end mt-1 fw-bold">
    <div>
      <%= start_and_end_time_with_timezone(@event, tz) %>
    </div>
    <div>
      <%= I18n.t tz, scope: :timezones %>
      <%= content_tag(:small, t("timezone.utc_label"), class: "text-secondary fw-normal") if tz == "Etc/UTC" %>
      <%= icon('fas', 'sun', data: { bs_toggle: 'tooltip', bs_placement: 'top', title: 'Somera/Vintra tempo' }) if @event.dst? %>
    </div>
  </div>
<% end %>
