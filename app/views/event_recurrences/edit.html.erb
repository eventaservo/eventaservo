<div class="container py-4">
  <div class="box-white">
    <h4 class="mb-3"><%= t("recurrences.edit_title", event: @event.title) %></h4>
    <p class="text-body-secondary"><%= t("recurrences.edit_subtitle") %></p>
    <hr>
    <%= render "form", recurrence: @recurrence, event: @event %>

    <hr class="my-4">
    <h5 class="text-danger"><%= t("recurrences.danger_zone") %></h5>
    <%= button_to t("recurrences.delete_recurrence"),
        event_recurrence_path(event_code: @event.ligilo),
        method: :delete,
        params: { delete_future_events: "1" },
        class: "btn btn-outline-danger btn-sm",
        data: { turbo_confirm: t("recurrences.delete_confirm") } %>
  </div>
</div>
