<nav aria-label="breadcrumb">
  <ol class="breadcrumb small mb-2">
    <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
    <li class="breadcrumb-item active" aria-current="page">Redirektoj</li>
  </ol>
</nav>

<div class="box-white">
  <div class="mb-3 d-flex justify-content-between align-items-center">
    <div class="lead">Eventaj Redirektoj</div>
    <%= link_to "Nova Redirekto", new_admin_redirection_path, class: "button-new-link" %>
  </div>

  <%= form_with url: admin_redirections_path, method: :get, local: true, class: "mb-3" do |f| %>
    <div class="row g-2 align-items-end">
      <div class="col-md-4">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Malnova URL</label>
        <%= text_field_tag :old_url, params[:old_url], class: "form-control form-control-sm", placeholder: "Serĉi malnovan URL..." %>
      </div>
      <div class="col-md-4">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Nova URL</label>
        <%= text_field_tag :new_url, params[:new_url], class: "form-control form-control-sm", placeholder: "Serĉi novan URL..." %>
      </div>
      <div class="col-md-auto d-flex gap-2">
        <%= f.submit "Filtri", class: "button-submit" %>
        <%= link_to "Nuligi", admin_redirections_path, class: "button-cancel" %>
      </div>
    </div>
  <% end %>

  <div class="border rounded overflow-hidden small">
    <div class="row g-0 align-items-center bg-success text-white text-uppercase fw-bold px-2 py-2 smaller">
      <div class="col">Malnova URL</div>
      <div class="col">Nova URL</div>
      <div class="col-1 text-center">Hits</div>
    </div>

    <% @redirections.each_with_index do |redirection, i| %>
      <%= link_to edit_admin_redirection_path(redirection), class: "row g-0 align-items-center px-2 py-1 small hover-row text-decoration-none text-dark #{'border-bottom' unless i == @redirections.size - 1} #{'bg-body-tertiary' if i.odd?}" do %>
        <div class="col text-truncate fw-medium"><%= redirection.old_short_url %></div>
        <div class="col text-truncate text-body-secondary"><%= redirection.new_short_url %></div>
        <div class="col-1 text-center text-body-secondary"><%= redirection.hits %></div>
      <% end %>
    <% end %>

    <% if @redirections.empty? %>
      <div class="p-4 text-center text-body-secondary">
        <%= icon('fas', 'search', class: 'fa-2x mb-3 opacity-25') %>
        <p>Neniu redirekto trovita.</p>
      </div>
    <% end %>
  </div>

  <%= render "shared/pagination", pagy: @pagy %>
</div>
