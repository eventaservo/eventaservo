<nav aria-label="breadcrumb">
  <ol class="breadcrumb small mb-2">
    <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
    <li class="breadcrumb-item active" aria-current="page">Organizaĵoj</li>
  </ol>
</nav>

<div class="box-white">
  <div class="lead">Ĉiuj organizaĵoj</div>

  <%= form_with url: admin_organizations_path, method: :get, local: true, class: "mb-3" do |f| %>
    <div class="row g-2 align-items-end">
      <div class="col-md-4">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Nomo</label>
        <%= text_field_tag :name_cont, params[:name_cont], class: "form-control form-control-sm", placeholder: "Serĉi nomon..." %>
      </div>
      <div class="col-md-4">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Lando</label>
        <%= select_tag :country_id_eq, options_from_collection_for_select(@countries, :id, :name, params[:country_id_eq]), include_blank: "Ĉiuj", class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-auto d-flex gap-2">
        <%= f.submit "Filtri", class: "btn btn-sm btn-success" %>
        <%= link_to "Nuligi", admin_organizations_path, class: "btn btn-sm btn-outline-secondary" %>
      </div>
    </div>
  <% end %>

  <div class="border rounded overflow-hidden small">
    <div class="row g-0 align-items-center bg-success text-white text-uppercase fw-bold px-2 py-2 smaller">
      <div class="col-1">ID</div>
      <div class="col">Nomo</div>
      <div class="col-2">Mallonga nomo</div>
      <div class="col-2">Lando / Urbo</div>
      <div class="col-1 text-center">Uzantoj</div>
      <div class="col-1 text-center">Eventoj</div>
    </div>

    <% @organizations.each_with_index do |organization, i| %>
      <%= link_to admin_organization_path(organization), class: "row g-0 align-items-center px-2 py-1 small hover-row text-decoration-none text-dark #{'border-bottom' unless i == @organizations.size - 1} #{'bg-body-tertiary' if i.odd?}" do %>
        <div class="col-1 text-body-secondary"><%= organization.id %></div>
        <div class="col fw-medium"><%= organization.name %></div>
        <div class="col-2 text-body-secondary"><%= organization.short_name %></div>
        <div class="col-2 text-body-secondary text-truncate">
          <%= organization.country&.name %><br>
          <span class="smaller"><%= organization.city %></span>
        </div>
        <div class="col-1 text-center"><%= organization.users.count %></div>
        <div class="col-1 text-center"><%= organization.events.count %></div>
      <% end %>
    <% end %>

    <% if @organizations.empty? %>
      <div class="p-4 text-center text-body-secondary">
        <%= icon('fas', 'search', class: 'fa-2x mb-3 opacity-25') %>
        <p>Neniu organizaĵo trovita.</p>
      </div>
    <% end %>
  </div>

  <div class="d-flex justify-content-center small pt-3">
    <%= raw pagy_bootstrap_nav(@pagy, params: request.GET) %>
  </div>
</div>
