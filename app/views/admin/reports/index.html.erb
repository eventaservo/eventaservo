<nav aria-label="breadcrumb">
  <ol class="breadcrumb small mb-2">
    <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
    <li class="breadcrumb-item active" aria-current="page">Raportoj</li>
  </ol>
</nav>

<div class="box-white">
  <div class="lead mb-3">Eventaj Raportoj</div>

  <%= form_with url: admin_reports_path, method: :get, local: true, class: "mb-3" do |f| %>
    <div class="row g-2 align-items-end">
      <div class="col-md-4">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Titolo de la raporto</label>
        <%= text_field_tag :title, params[:title], class: "form-control form-control-sm", placeholder: "Serĉi raporton..." %>
      </div>
      <div class="col-md-4">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Titolo de la evento</label>
        <%= text_field_tag :event_title, params[:event_title], class: "form-control form-control-sm", placeholder: "Serĉi eventon..." %>
      </div>
      <div class="col-md-auto d-flex gap-2">
        <%= f.submit "Filtri", class: "btn btn-sm btn-success" %>
        <%= link_to "Nuligi", admin_reports_path, class: "btn btn-sm btn-outline-secondary" %>
      </div>
    </div>
  <% end %>

  <div class="border rounded overflow-hidden small">
    <div class="row g-0 align-items-center bg-success text-white text-uppercase fw-bold px-2 py-2 smaller">
      <div class="col">Evento</div>
      <div class="col-3">Uzanto</div>
      <div class="col-3">Titolo de la raporto</div>
    </div>

    <% @reports.each_with_index do |report, i| %>
      <%= link_to admin_report_path(report), class: "row g-0 align-items-center px-2 py-1 small hover-row text-decoration-none text-dark #{'border-bottom' unless i == @reports.size - 1} #{'bg-body-tertiary' if i.odd?}" do %>
        <div class="col fw-medium text-truncate"><%= report.event.title %></div>
        <div class="col-3 text-body-secondary text-truncate"><%= report.user&.name %></div>
        <div class="col-3 text-body-secondary text-truncate"><%= report.title %></div>
      <% end %>
    <% end %>

    <% if @reports.empty? %>
      <div class="p-4 text-center text-body-secondary">
        <%= icon('fas', 'search', class: 'fa-2x mb-3 opacity-25') %>
        <p>Neniu raporto trovita.</p>
      </div>
    <% end %>
  </div>

  <div class="d-flex justify-content-center small pt-3">
    <%= @pagy.series_nav(:bootstrap) %>
  </div>
</div>
