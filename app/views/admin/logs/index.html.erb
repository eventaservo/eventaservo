<nav aria-label="breadcrumb">
  <ol class="breadcrumb small mb-2">
    <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
    <li class="breadcrumb-item active" aria-current="page">Logs</li>
  </ol>
</nav>

<div class="box-white">
  <div class="lead">Logs</div>

  <%= form_with url: admin_logs_path, method: :get, local: true, class: "mb-3" do |f| %>
    <div class="row g-2 align-items-end">
      <div class="col-6 col-md-2">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Ekde</label>
        <%= date_field_tag :start_date, params[:start_date], class: "form-control form-control-sm" %>
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Ĝis</label>
        <%= date_field_tag :end_date, params[:end_date], class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-3">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Uzanto</label>
        <%= text_field_tag :user_name, params[:user_name], class: "form-control form-control-sm", placeholder: "Serĉi uzanton..." %>
      </div>
      <div class="col-md-3">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Teksto</label>
        <%= text_field_tag :text, params[:text], class: "form-control form-control-sm", placeholder: "Serĉi tekston..." %>
      </div>
      <div class="col-md-auto d-flex gap-2">
        <%= f.submit "Filtri", class: "btn btn-sm btn-success" %>
        <%= link_to "Nuligi", admin_logs_path, class: "btn btn-sm btn-outline-secondary" %>
      </div>
    </div>
  <% end %>

  <div class="border rounded overflow-hidden small">
    <div class="row g-0 align-items-center bg-success text-white text-uppercase fw-bold px-2 py-2 smaller">
      <div class="col-2">Dato (UTC)</div>
      <div class="col-2">Uzanto</div>
      <div class="col">Teksto</div>
      <div class="col-2">Agoj</div>
    </div>

    <% @logs.each_with_index do |log, i| %>
      <div class="row g-0 align-items-center px-2 py-1 small <%= 'border-bottom' unless i == @logs.size - 1 %> <%= 'bg-body-tertiary' if i.odd? %>">
        <div class="col-2 fw-semibold text-success-emphasis small"><%= log.created_at.strftime("%d/%m/%Y %H:%M") %></div>
        <div class="col-2 fw-medium text-truncate"><%= log.user&.name %></div>
        <div class="col text-body-secondary"><%= log.text %></div>
        <div class="col-2 d-flex flex-wrap gap-1">
          <% if log.event_id && (event = @events[log.event_id.to_i]) %>
            <%= link_to "Evento", event_url(code: event.ligilo), target: "_blank", class: "badge bg-secondary text-decoration-none" %>
          <% end %>
          <% if log.organization_id && (org = @organizations[log.organization_id.to_i]) %>
            <%= link_to "Organizo", organization_url(org.short_name), target: "_blank", class: "badge bg-secondary text-decoration-none" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @logs.empty? %>
      <div class="p-4 text-center text-body-secondary">
        <%= icon('fas', 'search', class: 'fa-2x mb-3 opacity-25') %>
        <p>Neniu protokolo trovita.</p>
      </div>
    <% end %>
  </div>

  <%= render "shared/pagination", pagy: @pagy %>
</div>
