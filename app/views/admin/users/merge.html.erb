<nav aria-label="breadcrumb">
  <ol class="breadcrumb small mb-2">
    <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
    <li class="breadcrumb-item"><%= link_to "Users", admin_users_path %></li>
    <li class="breadcrumb-item"><%= link_to @user.name, admin_user_path(@user) %></li>
    <li class="breadcrumb-item active" aria-current="page">Merge</li>
  </ol>
</nav>

<div class="box-white">
  <div class="lead mb-3">Merge Users</div>

  <div class="alert alert-warning">
    <strong>Warning:</strong> This will transfer all events, organization memberships, and logs from
    <strong><%= @user.name %></strong> to the selected target user, then delete this account.
    This action cannot be undone.
  </div>

  <%= form_with url: merge_admin_user_path(@user), method: :post, local: true do |f| %>
    <div class="mb-3">
      <label class="form-label fw-bold small text-uppercase text-body-secondary">
        Transfer everything to
      </label>
      <%= select_tag "merge_users[target_user_id]",
        options_for_select(@user_list),
        class: "form-select",
        required: true %>
    </div>

    <div class="mt-4 d-flex gap-2">
      <%= f.submit "Merge", class: "btn btn-warning",
        data: { confirm: "Are you absolutely sure? This cannot be undone." } %>
      <%= link_to "Cancel", admin_user_path(@user), class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
