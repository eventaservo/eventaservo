<nav aria-label="breadcrumb">
  <ol class="breadcrumb small mb-2">
    <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
    <li class="breadcrumb-item active" aria-current="page">Users</li>
  </ol>
</nav>

<div class="box-white">
  <div class="lead mb-3">Users</div>

  <%# ── Scopes ──────────────────────────────────────────── %>
  <div class="d-flex gap-2 mb-3">
    <% scopes = [["Enabled", "enabled"], ["Disabled", "disabled"], ["Abandoned", "abandoned"], ["Not confirmed", "not_confirmed"]] %>
    <% current_scope = params[:scope].presence || "enabled" %>
    <% scopes.each do |label, scope| %>
      <%= link_to label, admin_users_path(scope: scope),
        class: "btn btn-sm #{current_scope == scope ? "btn-success" : "btn-outline-secondary"}" %>
    <% end %>
  </div>

  <%# ── Filters ─────────────────────────────────────────── %>
  <%= form_with url: admin_users_path, method: :get, local: true, class: "mb-3" do |f| %>
    <%= hidden_field_tag :scope, params[:scope] %>
    <div class="row g-2 align-items-end">
      <div class="col-md-2">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Name</label>
        <%= text_field_tag :name, params[:name], class: "form-control form-control-sm", placeholder: "Search name..." %>
      </div>
      <div class="col-md-2">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Email</label>
        <%= text_field_tag :email, params[:email], class: "form-control form-control-sm", placeholder: "Search email..." %>
      </div>
      <div class="col-md-2">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Username</label>
        <%= text_field_tag :username, params[:username], class: "form-control form-control-sm", placeholder: "Search username..." %>
      </div>
      <div class="col-md-2">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Country</label>
        <%= select_tag :country_id,
          options_from_collection_for_select(Country.order(:name), :id, :name, params[:country_id]&.to_i),
          include_blank: "All countries",
          class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-auto d-flex gap-2">
        <%= f.submit "Filter", class: "btn btn-sm btn-success" %>
        <%= link_to "Clear", admin_users_path(scope: params[:scope]), class: "btn btn-sm btn-outline-secondary" %>
      </div>
    </div>
  <% end %>

  <%# ── Table ───────────────────────────────────────────── %>
  <div class="border rounded overflow-hidden small">
    <div class="row g-0 align-items-center bg-success text-white text-uppercase fw-bold px-2 py-2 smaller">
      <div class="col-3">Name</div>
      <div class="col-3">Email</div>
      <div class="col-1">City</div>
      <div class="col-2">Country</div>
      <div class="col-1">Username</div>
      <div class="col-1">Events</div>
      <div class="col-1">Active?</div>
    </div>

    <% @users.each_with_index do |user, i| %>
      <%= link_to admin_user_path(user), class: "row g-0 align-items-center px-2 py-1 small hover-row text-decoration-none text-dark #{'border-bottom' unless i == @users.size - 1} #{'bg-body-tertiary' if i.odd?}" do %>
        <div class="col-3 fw-medium text-truncate"><%= user.name %></div>
        <div class="col-3 text-body-secondary text-truncate"><%= user.email %></div>
        <div class="col-1 text-body-secondary text-truncate"><%= user.city %></div>
        <div class="col-2 text-body-secondary text-truncate"><%= montras_flagon(user.country) %> <%= user.country&.name %></div>
        <div class="col-1 text-body-secondary text-truncate"><%= user.username %></div>
        <div class="col-1 text-body-secondary"><%= user.events_count %></div>
        <div class="col-1">
          <% if user.active? %>
            <span class="badge bg-success-subtle text-success">Yes</span>
          <% else %>
            <span class="badge bg-danger-subtle text-danger">No</span>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <% if @users.empty? %>
      <div class="p-4 text-center text-body-secondary">
        <%= icon('fas', 'search', class: 'fa-2x mb-3 opacity-25') %>
        <p>No users found.</p>
      </div>
    <% end %>
  </div>

  <div class="d-flex justify-content-center small pt-3">
    <%= @pagy.series_nav(:bootstrap) %>
  </div>
</div>
