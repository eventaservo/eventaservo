<nav aria-label="breadcrumb">
  <ol class="breadcrumb small mb-2">
    <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
    <li class="breadcrumb-item active" aria-current="page">Recurring Events</li>
  </ol>
</nav>

<div class="box-white">
  <div class="lead mb-3">Recurring Events</div>

  <%= form_with url: admin_event_recurrences_path, method: :get, local: true, class: "mb-3" do %>
    <div class="row g-2 align-items-end">
      <div class="col-auto">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Status</label>
        <%= select_tag :active,
          options_for_select([["All", ""], ["Active", "1"], ["Inactive", "0"]], params[:active]),
          class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto">
        <%= submit_tag "Filter", class: "button-submit" %>
      </div>
    </div>
  <% end %>

  <% if @recurrences.any? %>
    <div class="row-detailed-list">
      <% @recurrences.each do |recurrence| %>
        <% presenter = EventRecurrencePresenter.new(recurrence:) %>
        <%= link_to admin_event_recurrence_path(recurrence), class: "row-detailed" do %>
          <div class="row-detailed-accent <%= recurrence.active? ? 'bg-color-green' : 'bg-color-gray' %>"></div>
          <div class="row-detailed-body">
            <div class="row-detailed-info">
              <div class="row-detailed-title">
                <%= event_flag(recurrence.master_event) %>
                <%= recurrence.master_event.title %>
              </div>
              <div class="row-detailed-meta">
                <%= presenter.description %>
                <% if recurrence.end_type_on_date? %>
                  &middot; Ends <%= format_date(recurrence.end_date, style: :short) %>
                <% end %>
                &middot; <%= recurrence.master_event.recurrent_child_events.size %> child events
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="d-flex justify-content-center small pt-3">
      <%== pagy_bootstrap_nav(@pagy, params: request.GET) %>
    </div>
  <% else %>
    <p class="text-body-secondary">No recurring events found.</p>
  <% end %>
</div>
