<nav aria-label="breadcrumb">
  <ol class="breadcrumb small mb-2">
    <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
    <li class="breadcrumb-item active" aria-current="page">Recurring Events</li>
  </ol>
</nav>

<div class="box-white">
  <div class="lead mb-3">Recurring Events</div>

  <%= form_with url: admin_event_recurrences_path, method: :get, local: true, class: "mb-3" do %>
    <div class="row g-2 align-items-end">
      <div class="col-auto">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Status</label>
        <%= select_tag :active,
          options_for_select([["All", ""], ["Active", "1"], ["Inactive", "0"]], params[:active]),
          class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto">
        <label class="form-label smaller text-uppercase fw-bold text-body-secondary mb-1">Frequency</label>
        <%= select_tag :frequency,
          options_for_select([["All", ""], ["Daily", "daily"], ["Weekly", "weekly"], ["Monthly", "monthly"], ["Yearly", "yearly"]], params[:frequency]),
          class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto">
        <%= submit_tag "Filter", class: "btn btn-sm btn-success" %>
      </div>
    </div>
  <% end %>

  <% if @recurrences.any? %>
    <div class="border rounded overflow-hidden small">
      <div class="row g-0 align-items-center bg-success text-white text-uppercase fw-bold px-2 py-2 smaller">
        <div class="col">Event</div>
        <div class="col-4">Recurrence</div>
        <div class="col-1 text-center">Children</div>
        <div class="col-1 text-center">Status</div>
      </div>

      <% @recurrences.each_with_index do |recurrence, i| %>
        <%= link_to admin_event_recurrence_path(recurrence), class: "row g-0 align-items-center px-2 py-1 small hover-row text-decoration-none text-dark #{('border-bottom' unless i == @recurrences.size - 1)} #{('bg-body-tertiary' if i.odd?)}" do %>
          <div class="col fw-medium text-truncate">
            <%= event_flag(recurrence.master_event) %>
            <%= recurrence.master_event.title %>
          </div>
          <div class="col-4 text-body-secondary text-truncate">
            <%= recurrence_description(recurrence) %>
            <% if recurrence.end_type_on_date? %>
              <span class="text-body-tertiary">&mdash; until <%= format_date(recurrence.end_date, style: :short) %></span>
            <% end %>
          </div>
          <div class="col-1 text-center"><%= recurrence.master_event.recurrent_child_events.size %></div>
          <div class="col-1 text-center"><%= recurrence_status_badge(recurrence) %></div>
        <% end %>
      <% end %>
    </div>

    <div class="d-flex justify-content-center small pt-3">
      <%== pagy_bootstrap_nav(@pagy, params: request.GET) %>
    </div>
  <% else %>
    <p class="text-body-secondary">No recurring events found.</p>
  <% end %>
</div>
