<nav aria-label="breadcrumb">
  <ol class="breadcrumb small mb-2">
    <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
    <li class="breadcrumb-item"><%= link_to "Recurring Events", admin_event_recurrences_path %></li>
    <li class="breadcrumb-item active" aria-current="page"><%= @recurrence.master_event.title %></li>
  </ol>
</nav>

<%# Recurrence details card %>
<div class="box-white mb-3">
  <div class="d-flex align-items-center gap-3 mb-3">

    <div class="flex-grow-1">
      <div class="d-flex align-items-center gap-2 mb-1 justify-content-between">
        <h5 class="fw-bold mb-0"><%= @recurrence.master_event.title %></h5>
        <%= @presenter.badge_html %>
      </div>
      <div class="text-body-secondary small">
        <i class="fas fa-redo-alt me-1"></i><%= @presenter.description %>
        <span class="mx-1">&middot;</span>
        <i class="fas fa-calendar-check me-1"></i><%= @recurrence.end_type_on_date? ? "Ends #{format_date(@recurrence.end_date, style: :short)}" : "No end date" %>
      </div>
      <div>
        <%= link_to "View master event", event_path(code: @recurrence.master_event.ligilo), class: "py-2 small" %>
      </div>
    </div>
  </div>

  <div class="buttons-footer">
    <% if @recurrence.active? %>
      <%= button_to "Deactivate", deactivate_admin_event_recurrence_path(@recurrence),
          method: :patch, class: "button-delete me-auto",
          data: { turbo_confirm: "Deactivate this recurrence?" } %>
    <% end %>
    <% if @recurrence.active? %>
      <%= link_to "Edit", edit_event_recurrence_path(event_code: @recurrence.master_event.ligilo), class: "button-submit" %>
    <% else %>
      <%= button_to "Reactivate", reactivate_admin_event_recurrence_path(@recurrence),
          method: :patch, class: "button-submit" %>
    <% end %>
  </div>
</div>

<%# All events in the series %>
<div class="box-white">
  <div class="lead mb-3">Events in series (<%= @pagy.count %>)</div>

  <% if @series_events.any? %>
    <div class="border rounded overflow-hidden small">
      <div class="row g-0 align-items-center bg-success text-white text-uppercase fw-bold px-2 py-2 smaller">
        <div class="col-2">Date</div>
        <div class="col">Title</div>
        <div class="col-2 text-center">Type</div>
      </div>

      <% @series_events.each_with_index do |event, i| %>
        <% is_master = event.id == @recurrence.master_event.id %>
        <% is_past = event.date_start < Time.current %>
        <%= link_to event_path(code: event.ligilo), class: "row g-0 align-items-center px-2 py-1 small hover-row text-decoration-none text-dark #{event_color_class(event)} #{('border-bottom' unless i == @series_events.size - 1)} #{('bg-body-tertiary' if i.odd?)} #{('opacity-50' if is_past && !is_master)}" do %>
          <div class="col-2 fw-semibold text-success-emphasis small">
            <%= format_date(event.komenca_dato, style: :compact) %>
          </div>
          <div class="col fw-medium text-truncate">
            <%= event_flag(event) %> <%= event.title %>
          </div>
          <div class="col-2 text-center">
            <%= EventPresenter.new(event:).recurrence_type_badge_html %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="d-flex justify-content-center small pt-3">
      <%== pagy_bootstrap_nav(@pagy) %>
    </div>
  <% else %>
    <p class="text-body-secondary">No events in this series yet.</p>
  <% end %>
</div>
