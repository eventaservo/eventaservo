<div class="mb-5">
  <h6 class="text-uppercase fw-bold text-body-secondary mb-2 small">Dismissal action — <code>.button-cancel</code></h6>
  <p class="text-body-secondary small mb-3">
    Extends <code>.btn-link</code>. Text color: <code>$grayDark</code> (#999) → <code>$red</code> (#B91D47) on hover.
    Use for any action that discards or aborts: Cancel, Discard, Void, etc.
    Not interchangeable with <code>.button-back</code>, which is for page navigation.
  </p>

  <div class="border rounded p-3 mb-2 bg-body-tertiary">
    <div class="d-flex flex-wrap align-items-center gap-3">
      <div class="text-center">
        <button class="button-cancel">Cancel</button>
        <div class="text-body-secondary mt-1" style="font-size:11px">normal</div>
      </div>
      <div class="text-center">
        <button class="button-cancel" style="color:#B91D47;">Cancel</button>
        <div class="text-body-secondary mt-1" style="font-size:11px">hover</div>
      </div>
      <div class="text-center">
        <button class="button-cancel" style="outline:0;box-shadow:0 0 0 3px rgba(176,176,176,0.40);">Cancel</button>
        <div class="text-body-secondary mt-1" style="font-size:11px">focus</div>
      </div>
      <div class="text-center">
        <button class="button-cancel" disabled>Cancel</button>
        <div class="text-body-secondary mt-1" style="font-size:11px">disabled</div>
      </div>
    </div>
  </div>
  <div class="text-body-secondary mb-3" style="font-size:11px">
    Normal: <code>#999</code> (<code>$grayDark</code>) &nbsp;·&nbsp; Hover: <code>#B91D47</code> (<code>$red</code>) &nbsp;·&nbsp; No background fill
  </div>

  <p class="text-body-secondary small mb-2">Common labels for this button:</p>
  <div class="d-flex flex-wrap gap-2 mb-3">
    <button class="button-cancel">Cancel</button>
    <button class="button-cancel">Discard</button>
    <button class="button-cancel">Void</button>
  </div>

  <p class="text-body-secondary small mb-1">Void action</p>
  <div class="border rounded p-3 mb-2 bg-body-tertiary" style="max-width:480px">
    <p class="small mb-3">Mark this registration as void? The participant will be notified.</p>
    <div class="buttons-footer">
      <button class="button-cancel">Discard</button>
      <button class="button-submit">Process</button>
    </div>
  </div>
</div>
