<div class="card shadow-sm card-hover h-100 position-relative">
  <div class="card-body p-0">
    <!-- Top accent bar -->
    <div class="bg-success bg-opacity-10 border-bottom border-success border-opacity-25 px-3 py-3">
      <div class="d-flex align-items-center gap-3">
        <% if speaker[:avatar] %>
          <%= image_tag speaker[:avatar], alt: speaker[:name],
                class: "rounded-circle flex-shrink-0 object-fit-cover",
                size: "56x56" %>
        <% else %>
          <div class="bg-secondary-subtle rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:56px;height:56px">
            <i class="fas fa-user text-secondary"></i>
          </div>
        <% end %>
        <div>
          <h6 class="fw-bold mb-0 text-truncate">
            <a href="#" class="stretched-link text-decoration-none text-body"><%= speaker[:name] %></a>
          </h6>
          <span class="text-body-secondary small">
            <% if speaker[:country_code] %>
              <%= flag_icon(speaker[:country_code]) %>
            <% end %>
            <%= speaker[:country] %>
          </span>
        </div>
      </div>
    </div>

    <!-- Topics -->
    <div class="px-3 pt-3 pb-3">
      <div class="text-uppercase text-success fw-semibold small mb-2" style="font-size:0.7rem;letter-spacing:0.05em">
        <i class="fas fa-comments me-1"></i>Temoj
      </div>
      <p class="small mb-0"><%= speaker[:topics] %></p>
    </div>
  </div>
</div>
