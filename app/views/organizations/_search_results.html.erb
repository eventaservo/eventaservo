<div class="es-list__headers align-items-center">
  <div class="col-8 col-lg-10">Nomo</div>
  <div class="col-2 col-lg-1">
    <i class="far fa-calendar" data-bs-toggle="tooltip" data-bs-placement="top" title="Eventoj"></i>
  </div>
  <div class="col-2 col-lg-1">
    <i class="fas fa-users" data-bs-toggle="tooltip" data-bs-placement="top" title="Administrantoj kaj helpantoj"></i>
  </div>
</div>

<% @organizoj.each do |organizo| %>
  <%= render partial: 'organization_card', locals: { organizo: organizo } %>
<% end %>

<% if @organizoj.size.zero? %>
  <div class="text-center">
    Neniu rezulto
  </div>
<% end %>

<%= render "shared/pagination", pagy: @pagy %>
